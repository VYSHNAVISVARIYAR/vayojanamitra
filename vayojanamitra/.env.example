# AI API Keys - Multiple Keys for Rotation
# Gemini Keys (3 recommended for high volume)
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here  
GEMINI_API_KEY_3=your_gemini_api_key_3_here

# Groq Keys (3 recommended for high volume)
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here

# Optional: OpenRouter (fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database
MONGODB_URL=mongodb://localhost:27017/vayojanamitra

# Other existing environment variables...
# Add any other required environment variables from your existing setup
