# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
DB_NAME=vayojanamitra

# AI API Keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ChromaDB Configuration
CHROMA_PATH=./chroma_db

# Frontend URLs (for CORS)
FRONTEND_URLS=http://localhost:5173,http://localhost:5174,http://localhost:5177

# AI Model Configuration
DEFAULT_AI_MODEL=deepseek/deepseek-chat
EMBEDDING_MODEL=openai/text-embedding-3-small

# Income Thresholds (INR)
BPL_THRESHOLD=100000
MIDDLE_INCOME_THRESHOLD=300000

# Text Processing Limits
MAX_TEXT_LENGTH=8000
MIN_TEXT_LENGTH=100

# Admin Credentials (for development)
ADMIN_EMAIL=admin@vayojanamitra.com
ADMIN_PASSWORD=admin123
